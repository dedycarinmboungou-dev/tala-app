## ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

## ── Base de données ───────────────────────────────────────────────────────────
DB_PATH=./tala.db
# DB_PATH=/data/tala.db   # décommente sur Render (Persistent Disk)

## ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=

## ── Anthropic (Coach IA + Rapport PDF) ───────────────────────────────────────
ANTHROPIC_API_KEY=

## ── Meta Ads (OAuth) ──────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/meta/oauth/callback

## ── FedaPay (paiement abonnement) ────────────────────────────────────────────
FEDAPAY_SECRET_KEY=
FEDAPAY_ENV=sandbox
# FEDAPAY_WEBHOOK_SECRET=    # clé HMAC pour valider les webhooks
# FEDAPAY_CALLBACK_URL=      # surcharge l'URL de callback webhook
APP_URL=https://tala.app

## ── Brevo (emails transactionnels) ───────────────────────────────────────────
BREVO_API_KEY=
BREVO_FROM_EMAIL=hello@tala.app
BREVO_FROM_NAME=Tala

## ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=

## ── Chariow ───────────────────────────────────────────────────────────────────
# CHARIOW_API_BASE=https://api.chariow.com/v1   # optionnel, valeur par défaut

## ── CORS ──────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGIN=https://tala.app
